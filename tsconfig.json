{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "src",
    "migrations"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/admin_panel_source"
  ]
}